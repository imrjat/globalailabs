            <li><a href="./stir.html" class="hover:text-signal transition-colors uppercase">Stir</a></li>
            <li><a href="./carbon.html" class="hover:text-signal transition-colors uppercase">Carbon</a></li>
            <li><a href="./h2o.html" class="hover:text-signal transition-colors uppercase">H2O</a></li>
            <li><a href="./team.html" class="hover:text-signal transition-colors uppercase">Team</a></li>
            <li><a href="./careers.html" class="hover:text-signal transition-colors uppercase">Careers</a></li>
            <li><a href="./connect.html" class="hover:text-signal transition-colors uppercase">Connect</a></li>
          </ul>
        </div>
        <div class="md:col-span-4 flex flex-col gap-6">
          <div>
            <div class="text-[11px] tracking-[0.08em] uppercase text-muted mb-4">business inquiries</div>
            <a href="mailto:connect@globalailabs.in" class="text-lg font-bold text-signal hover:underline">connect@globalailabs.in</a>
          </div>
          <div>
            <button id="go-up-btn" class="magnetic inline-flex items-center gap-2 px-6 py-2 border border-line-dark text-ice text-[11px] font-bold tracking-[0.08em] uppercase rounded-full hover:bg-ice hover:text-ink hover:border-ice transition-all duration-300">
              go up ↑
            </button>
          </div>
        </div>
      </div>

      <!-- Giant Wordmark Logo -->
      <div class="w-full border-t border-line-dark pt-12 overflow-hidden">
        <img src="./assets/img/globalailabs.png" alt="Global AI Labs" class="w-full opacity-10" style="filter: invert(1); max-height: 18vw; object-fit: contain; object-position: left;">
      </div>

      <!-- Bottom row -->
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] tracking-[0.08em] uppercase text-muted border-t border-line-dark pt-8">
        <div>© 2026 Global AI Labs. All rights reserved.</div>
        <div class="flex gap-4">
          <a href="#" class="hover:text-ice transition-colors">Privacy Policy</a>
          <span>/</span>
          <a href="#" class="hover:text-ice transition-colors">Terms of Service</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Scripts -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>
  <script>
    // Register ScrollTrigger plugin
    gsap.registerPlugin(ScrollTrigger);

    // Header dark/light detection — invert logo on dark sections
    (function() {
      const header = document.getElementById('site-header');
      const logo = header && header.querySelector('.header-logo');
      const startBtn = header && header.querySelector('.header-btn');
      const menuBtn = header && header.querySelector('.header-menu-btn');
      const darkSections = document.querySelectorAll('.dark-section, footer');

      function setHeaderDark(isDark) {
        if (!header) return;
        if (isDark) {
          if (logo) {
            logo.style.filter = 'invert(1)';
            logo.style.mixBlendMode = 'normal';
          }
          if (startBtn) {
            startBtn.classList.remove('border-ink', 'text-ink', 'hover:bg-ink', 'hover:text-ice');
            startBtn.classList.add('border-ice', 'text-ice', 'hover:bg-ice', 'hover:text-ink');
          }
          if (menuBtn) {
            menuBtn.classList.remove('bg-ink', 'text-ice');
            menuBtn.classList.add('bg-ice', 'text-ink');
          }
        } else {
          if (logo) {
            logo.style.filter = 'none';
            logo.style.mixBlendMode = 'multiply';
          }
          if (startBtn) {
            startBtn.classList.remove('border-ice', 'text-ice', 'hover:bg-ice', 'hover:text-ink');
            startBtn.classList.add('border-ink', 'text-ink', 'hover:bg-ink', 'hover:text-ice');
          }
          if (menuBtn) {
            menuBtn.classList.remove('bg-ice', 'text-ink');
            menuBtn.classList.add('bg-ink', 'text-ice');
          }
        }
      }

      if (darkSections.length && window.ScrollTrigger) {
        darkSections.forEach(section => {
          ScrollTrigger.create({
            trigger: section,
            start: 'top 60px',
            end: 'bottom 60px',
            onEnter: () => setHeaderDark(true),
            onLeave: () => setHeaderDark(false),
            onEnterBack: () => setHeaderDark(true),
            onLeaveBack: () => setHeaderDark(false),
          });
        });
      }

      // Service cards accordion toggle
      const serviceCards = document.querySelectorAll('.service-card');
      serviceCards.forEach(card => {
        card.addEventListener('click', () => {
          const isActive = card.classList.contains('active');
          serviceCards.forEach(c => c.classList.remove('active'));
          if (!isActive) card.classList.add('active');
        });
      });
    })();
  </script>
  <script type="module" src="./assets/js/main.js"></script>
</body>
</html>
