<!DOCTYPE html>
<html lang="en" class="lenis">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Global AI Labs — Creative | Production | Content | Digital</title>
  <meta name="description" content="An integrated agency with a digital-first approach across creative strategy, campaigns, production, content, influencer marketing, digital and social media.">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Global AI Labs — Creative | Production | Content | Digital">
  <meta property="og:description" content="An integrated agency with a digital-first approach across creative strategy, campaigns, production, content, influencer marketing, digital and social media.">

  <!-- Tailwind & Custom Styles -->
  <link rel="stylesheet" href="./assets/css/styles.css">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-ice text-ink antialiased selection:bg-signal selection:text-ink">

  <!-- Noise Background -->
  <div class="noise-overlay"></div>

  <!-- Grid Overlay lines (Desktop only) -->
  <div class="grid-overlay hidden md:grid">
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
  </div>

  <!-- First-Visit Loader Overlay -->
  <div id="loader-overlay" class="loader-overlay" role="progressbar" aria-valuemin="0" aria-valuemax="100">
    <div class="flex justify-between items-start w-full">
      <div class="text-[11px] tracking-[0.08em] uppercase text-smoke">loading</div>
      <div class="text-[11px] tracking-[0.08em] uppercase text-smoke">global ai labs</div>
    </div>
    <div class="w-full text-center">
      <h1 class="loader-title text-ice font-black text-6xl md:text-8xl tracking-[-0.05em] uppercase select-none">
        global ai labs
      </h1>
    </div>
    <div class="flex justify-between items-end w-full">
      <div class="text-[11px] tracking-[0.08em] uppercase text-smoke">system ready</div>
      <div class="loader-progress text-signal font-black text-8xl md:text-[12rem] leading-none tracking-[-0.05em]">
        00
      </div>
    </div>
  </div>

  <!-- Page Transition Screen Sweep Overlay -->
  <div class="transition-overlay">
    <div class="transition-text">GLOBAL</div>
  </div>

  <!-- Fixed Navigation Header -->
  <header id="site-header" class="fixed top-0 left-0 w-full z-[1000] px-5 py-4 md:px-8 lg:px-12 flex justify-between items-center">
    <a href="./index.html" class="focus:outline-none focus:ring-2 focus:ring-signal focus:ring-offset-2 flex items-center">
      <img src="./assets/img/globalailabs.png" alt="Global AI Labs" class="h-5 md:h-6 w-auto header-logo" style="mix-blend-mode: multiply; filter: none;">
    </a>
    <div class="flex items-center gap-4">
      <a href="./connect.html" class="magnetic hidden md:inline-flex px-6 py-2 border border-ink text-ink text-[11px] font-bold tracking-[0.08em] uppercase rounded-full hover:bg-ink hover:text-ice transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-signal header-btn">
        connect
      </a>
      <button id="menu-trigger" aria-expanded="false" aria-controls="menu-overlay" class="magnetic px-6 py-2 bg-ink text-ice text-[11px] font-bold tracking-[0.08em] uppercase rounded-full hover:bg-signal hover:text-ink transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-signal header-menu-btn">
        <span class="menu-text">menu</span>
      </button>
    </div>
  </header>

  <!-- Fullscreen Dark Navigation Overlay -->
  <nav id="menu-overlay" aria-hidden="true" role="dialog" aria-modal="true" class="fixed top-0 left-0 w-full h-screen bg-ink text-ice z-[998] flex flex-col justify-between p-8 md:p-12 lg:p-16 pointer-events-none" style="clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);">
    <div class="flex justify-between items-start w-full mt-12 md:mt-6">
      <div class="text-[11px] tracking-[0.08em] uppercase text-muted">navigation</div>
      <div class="text-[11px] tracking-[0.08em] uppercase text-muted">global ai labs</div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center w-full">
      <div class="lg:col-span-8 flex flex-col gap-4">
        <a href="./index.html" class="menu-main-link group block text-4xl md:text-6xl lg:text-7xl font-black tracking-[-0.05em] uppercase hover:text-signal transition-colors focus:outline-none focus:ring-2 focus:ring-signal w-fit">
          home
        </a>
        <a href="./stir.html" class="menu-main-link group block text-4xl md:text-6xl lg:text-7xl font-black tracking-[-0.05em] uppercase hover:text-signal transition-colors focus:outline-none focus:ring-2 focus:ring-signal w-fit">
          stir
        </a>
        <a href="./carbon.html" class="menu-main-link group block text-4xl md:text-6xl lg:text-7xl font-black tracking-[-0.05em] uppercase hover:text-signal transition-colors focus:outline-none focus:ring-2 focus:ring-signal w-fit">
          carbon
        </a>
        <a href="./h2o.html" class="menu-main-link group block text-4xl md:text-6xl lg:text-7xl font-black tracking-[-0.05em] uppercase hover:text-signal transition-colors focus:outline-none focus:ring-2 focus:ring-signal w-fit">
          h2o
        </a>
        <a href="./team.html" class="menu-main-link group block text-4xl md:text-6xl lg:text-7xl font-black tracking-[-0.05em] uppercase hover:text-signal transition-colors focus:outline-none focus:ring-2 focus:ring-signal w-fit">
          team
        </a>
        <a href="./careers.html" class="menu-main-link group block text-4xl md:text-6xl lg:text-7xl font-black tracking-[-0.05em] uppercase hover:text-signal transition-colors focus:outline-none focus:ring-2 focus:ring-signal w-fit">
          careers
        </a>
        <a href="./connect.html" class="menu-main-link group block text-4xl md:text-6xl lg:text-7xl font-black tracking-[-0.05em] uppercase hover:text-signal transition-colors focus:outline-none focus:ring-2 focus:ring-signal w-fit">
          connect
        </a>
      </div>

      <div class="lg:col-span-4 flex flex-col gap-6 lg:border-l lg:border-line-dark lg:pl-12">
        <div>
          <div class="text-[11px] tracking-[0.08em] uppercase text-muted mb-3">capabilities</div>
          <ul class="flex flex-col gap-2">
            <li class="menu-secondary-item text-md md:text-lg font-bold hover:text-signal transition-colors">STRATEGY</li>
            <li class="menu-secondary-item text-md md:text-lg font-bold hover:text-signal transition-colors">PRODUCTION</li>
            <li class="menu-secondary-item text-md md:text-lg font-bold hover:text-signal transition-colors">CONTENT</li>
            <li class="menu-secondary-item text-md md:text-lg font-bold hover:text-signal transition-colors">CREATORS</li>
          </ul>
        </div>
        <div>
          <div class="text-[11px] tracking-[0.08em] uppercase text-muted mb-2">say hello</div>
          <a href="mailto:connect@globalailabs.in" class="menu-secondary-item text-md md:text-lg hover:underline text-signal">connect@globalailabs.in</a>
        </div>
      </div>
    </div>

    <div class="flex justify-between items-end w-full">
      <div class="text-[11px] tracking-[0.08em] uppercase text-muted">© 2026</div>
      <div class="text-[11px] tracking-[0.08em] uppercase text-muted">mumbai, india</div>
    </div>
  </nav>

  <main>
    <!-- Fullscreen Hero Section -->
    <section class="relative min-h-screen w-full flex flex-col justify-between px-5 pt-32 pb-16 md:px-8 lg:px-12 bg-ice overflow-hidden z-0">
      
      <!-- Placeholder grid lines for mobile -->
      <div class="absolute inset-0 z-[-1] pointer-events-none md:hidden flex justify-between px-5 opacity-40">
        <div class="h-full w-[1px] bg-line-light"></div>
        <div class="h-full w-[1px] bg-line-light"></div>
      </div>

      <!-- Floating Canvas Signal Device in Background -->
      <div class="absolute inset-0 z-[-1] pointer-events-none opacity-45">
        <canvas id="hero-canvas" class="w-full h-full"></canvas>
      </div>

      <!-- Centered Hero Copy -->
      <div class="max-w-6xl mx-auto w-full flex-grow flex flex-col items-center justify-center text-center relative z-10 gap-8 mt-12">
        <div class="hero-tagline text-[11px] font-black tracking-[0.15em] uppercase text-muted">
          [ AN INTEGRATED CREATIVE AGENCY ]
        </div>
        
        <h1 class="hero-wordmark text-[8vw] md:text-[6vw] font-black uppercase tracking-[-0.06em] leading-[0.88] select-none text-ink max-w-4xl">
          Global AI Labs
        </h1>
        
        <p class="hero-intro text-lg md:text-xl lg:text-2xl text-ink font-light leading-relaxed max-w-2xl">
          An integrated agency with a digital-first approach. Think creative strategy, campaigns, activations, influencer marketing, production, content, paid and organic search, and everything else a brand needs to navigate digital and social media.
        </p>
        
        <div class="flex flex-row flex-wrap justify-center gap-4 hero-ctas">
          <a href="./stir.html" class="magnetic px-8 py-4 bg-ink text-ice hover:bg-signal hover:text-ink text-[11px] font-black tracking-[0.08em] uppercase rounded-full transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-signal">
            View Work
          </a>
          <a href="./connect.html" class="magnetic px-8 py-4 border border-ink text-ink hover:bg-ink hover:text-ice text-[11px] font-black tracking-[0.08em] uppercase rounded-full transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-ink">
            Connect With Us
          </a>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 opacity-50 select-none">
        <span class="text-[9px] tracking-[0.15em] uppercase font-bold text-ink">scroll</span>
        <div class="w-[1px] h-6 bg-ink animate-bounce"></div>
      </div>
    </section>

    <!-- Trusted-by Section -->
    <section class="w-full bg-ice py-16 border-b border-line-light relative z-10 overflow-hidden">
      <div class="max-w-7xl mx-auto px-5 md:px-8 lg:px-12 flex flex-col gap-12">
        <span class="text-[9px] font-black tracking-[0.15em] uppercase text-muted text-center">TRUSTED BY LEADING BRANDS</span>
        <div class="logo-carousel-section">
          
