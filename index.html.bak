    </section>
    <!-- Bento Grid Product Features Section -->
    <section class="w-full bg-ice py-28 px-5 md:px-8 lg:px-12 relative z-10 border-b border-line-light">
      <div class="max-w-7xl mx-auto flex flex-col gap-16">
        <!-- Header -->
        <div class="max-w-3xl flex flex-col gap-4">
          <span class="text-[9px] font-black tracking-[0.15em] uppercase text-muted">[ AGENCY PILLARS ]</span>
          <h2 class="text-4xl md:text-6xl font-black uppercase tracking-[-0.05em] leading-[0.9] text-ink">
            Makers of the secret sauce
          </h2>
          <p class="text-lg text-muted font-light leading-relaxed max-w-2xl mt-2">
            We help brands navigate the world of digital and social media – armed with brand and creative strategy. Be it campaigns, websites, branding, activations, influencer marketing, paid and organic search and anything else your brand needs.
          </p>
        </div>

        <!-- Bento Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Bento Card 1: Stir (col-span-2 on large screen) -->
          <div class="glass-panel rounded-[24px] p-8 flex flex-col justify-between min-h-[300px] transition-all duration-300 hover:shadow-lg md:col-span-2">
            <div class="flex flex-col gap-4">
              <span class="text-[9px] font-bold tracking-[0.08em] text-muted font-mono uppercase">01 / CREATIVE AGENCY & CAMPAIGNS</span>
              <h3 class="text-2xl md:text-3xl font-black tracking-[-0.03em] uppercase text-ink">STIR</h3>
              <p class="text-sm text-muted font-light leading-relaxed max-w-xl">
                Our creative powerhouse. From campaign concepts and visual design to copy strategy and full-funnel digital activations, we stir emotions and create brand resonance.
              </p>
            </div>
            <div class="border-t border-line-light pt-6 mt-8 flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-line-light rounded-full text-[10px] uppercase font-bold text-muted font-mono">Campaign Briefs</span>
              <span class="px-3 py-1 bg-line-light rounded-full text-[10px] uppercase font-bold text-muted font-mono">Creative Strategy</span>
              <span class="px-3 py-1 bg-line-light rounded-full text-[10px] uppercase font-bold text-muted font-mono">Art Direction</span>
            </div>
          </div>

          <!-- Bento Card 2: Carbon (col-span-1) -->
          <div class="glass-panel rounded-[24px] p-8 flex flex-col justify-between min-h-[300px] transition-all duration-300 hover:shadow-lg col-span-1">
